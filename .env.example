# LunImago — environment variables
# Copy to .env and fill in the values.

# ── osu! API (required for scripts/fetch_osu_replays.py) ─────────────────────
# Create an OAuth app at: osu.ppy.sh/home/account/edit → OAuth → New OAuth Application
# Callback URL: http://localhost  (client credentials flow — no real redirect)
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# ── Fetch tuning (optional) ───────────────────────────────────────────────────
# Delay in seconds between API requests (default: 0.3)
OSU_RATE_DELAY=0.3

# ── Training (optional overrides) ────────────────────────────────────────────
# Passed directly to `lunimago train` — set here to avoid repeating on CLI
# LUNIMAGO_DEVICE=directml   # cuda | directml | rocm | mps | cpu | auto
# LUNIMAGO_EPOCHS=20
# LUNIMAGO_BATCH=128
# LUNIMAGO_WINDOW=32
